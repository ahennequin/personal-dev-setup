# GitHub (user identity — used as fallback when bot identity is not configured)
GITHUB_PAT=github_pat_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_USERNAME=ahennequin
GITHUB_REPOS=["owner/repo1","owner/repo2"]

# GitHub App (bot identity — optional; when set, all spec-kit API calls use
# the bot's installation token instead of the user's PAT)
# 1. Create a GitHub App at https://github.com/settings/apps
# 2. Install it on your repos, note the Installation ID
# 3. Generate a private key, save as bot-key.pem
# 4. Set the full path to the key file
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=
GITHUB_BOT_USERNAME=  # e.g. "speckit-bot[bot]"

# OpenCode
OPENCODE_MODEL=opencode/deepseek-v4-flash-free

# Paths
REPOS_BASE_PATH=/home/alex/Code
SPECKIT_DATA_PATH=/home/alex/.local/share/speckit

# API
API_PORT=8080
